# LLM Configuration
# Mode: enhance (always use LLM), fallback (OCR only on LLM error), disabled (OCR only)
LLM_MODE=disabled

# LLM Provider: openai or deepseek
LLM_PROVIDER=openai

# API Keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# LLM Model
LLM_MODEL=gpt-4o-mini

# Server Configuration
HOST=127.0.0.1
PORT=8000

# OCR Configuration
OCR_LANGUAGE=ch
